{%- comment -%}
  Kullanım: {% render 'product-card', product: product %}
{%- endcomment -%}

<article class="product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__image-wrap" tabindex="-1" aria-hidden="true">

    {%- if product.featured_image -%}
      <img
        class="product-card__image"
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | escape }}"
        width="600"
        height="800"
        loading="lazy"
      >
      {%- if product.images[1] -%}
        <img
          class="product-card__image-alt"
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt="{{ product.images[1].alt | escape }}"
          width="600"
          height="800"
          loading="lazy"
        >
      {%- endif -%}
    {%- else -%}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" width="48" height="48" style="color:var(--color-rose);" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {%- endif -%}

    {%- if product.tags contains 'new' or product.tags contains 'yeni' -%}
      <span class="product-card__badge">Yeni</span>
    {%- elsif product.compare_at_price > product.price -%}
      {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <span class="product-card__badge">-%{{ savings }}</span>
    {%- endif -%}

    <button class="product-card__wishlist" aria-label="{{ product.title }} istek listesine ekle" tabindex="-1" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>

    {%- if product.available -%}
      <div class="product-card__quick-add">
        <button
          class="product-card__quick-btn"
          type="button"
          onclick="velvetQuickAdd(event, '{{ product.variants.first.id }}')"
          aria-label="{{ product.title }} sepete ekle"
        >
          Sepete Ekle
        </button>
      </div>
    {%- endif -%}

  </a>

  <div class="product-card__info">
    {%- if product.collections.first -%}
      <p class="product-card__collection">{{ product.collections.first.title }}</p>
    {%- endif -%}
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <s class="product-card__price--compare">{{ product.compare_at_price | money }}</s>
      {%- endif -%}
      {{ product.price | money }}
    </p>
  </div>
</article>

<script>
  if (!window._velvetQuickAddBound) {
    window._velvetQuickAddBound = true;
    window.velvetQuickAdd = function (event, variantId) {
      event.preventDefault();
      event.stopPropagation();
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
        .then(function (r) { return r.json(); })
        .then(function () { window.location.href = '/cart'; })
        .catch(console.error);
    };
  }
</script>
