<header class="site-header" id="SiteHeader">
  <div class="header__inner">

    <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
      Vel<span>v</span>et
    </a>

    <nav class="header__nav" aria-label="Ana navigasyon">
      <div class="nav-item">
        <a href="{{ routes.root_url }}" class="nav-item__link">Ana Sayfa</a>
      </div>

      <div class="nav-item">
        <button class="nav-item__link" aria-haspopup="true" aria-expanded="false">
          Koleksiyonlar
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="nav-dropdown" role="menu">
          <div class="nav-dropdown__item"><a href="/collections/vibratorler-masaj" role="menuitem">Vibratörler &amp; Masaj</a></div>
          <div class="nav-dropdown__item"><a href="/collections/ic-giyim-kostum" role="menuitem">İç Giyim &amp; Kostüm</a></div>
          <div class="nav-dropdown__item"><a href="/collections/yagler-aksesuarlar" role="menuitem">Yağlar &amp; Aksesuarlar</a></div>
          <div class="nav-dropdown__item"><a href="/collections/ciftler-icin" role="menuitem">Çiftler İçin</a></div>
          <div class="nav-dropdown__item"><a href="/collections/all" role="menuitem">Tüm Ürünler</a></div>
        </div>
      </div>

      <div class="nav-item">
        <a href="/pages/hakkimizda" class="nav-item__link">Hakkımızda</a>
      </div>

      <div class="nav-item">
        <a href="/pages/iletisim" class="nav-item__link">İletişim</a>
      </div>
    </nav>

    <div class="header__actions">
      <a href="{{ routes.search_url }}" class="header__icon-btn" aria-label="Ara">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="m21 21-4.35-4.35"/>
        </svg>
      </a>

      <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Hesabım">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <a href="{{ routes.cart_url }}" class="header__icon-btn" aria-label="Sepet ({{ cart.item_count }} ürün)">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count" aria-label="{{ cart.item_count }} ürün">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
