<section class="hero">
  <div class="hero__bg">
    {%- if section.settings.background_image != blank -%}
      <img
        class="hero__bg-image"
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <svg class="hero__bg-image" style="opacity:0.07;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <pattern id="velvet-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="10" cy="10" r="1.5" fill="#C9A0A0"/>
            <circle cx="0"  cy="0"  r="0.5" fill="#C9A0A0"/>
            <circle cx="20" cy="0"  r="0.5" fill="#C9A0A0"/>
            <circle cx="0"  cy="20" r="0.5" fill="#C9A0A0"/>
            <circle cx="20" cy="20" r="0.5" fill="#C9A0A0"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#velvet-dots)"/>
      </svg>
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <p class="hero__eyebrow">{{ section.settings.eyebrow | default: 'Premium Çift Butiği' }}</p>

    <h1 class="hero__title">
      {%- if section.settings.title != blank -%}
        {{ section.settings.title }}
      {%- else -%}
        <em>Duyusallığın</em> <strong>zarif</strong> dünyasına hoş geldiniz
      {%- endif -%}
    </h1>

    <p class="hero__subtitle">
      {{ section.settings.subtitle | default: 'Her ürün, özel anlarınızı unutulmaz kılmak için özenle seçildi. Premium materyal, tam gizlilik.' }}
    </p>

    <div class="hero__actions">
      <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn-primary">
        {{ section.settings.cta1_text | default: 'Koleksiyonu Keşfet' }}
      </a>
      <a href="{{ section.settings.cta2_url | default: '/pages/hakkimizda' }}" class="btn btn-outline">
        {{ section.settings.cta2_text | default: 'Hakkımızda' }}
      </a>
    </div>
  </div>

  <div class="hero__scroll-hint" aria-hidden="true">Keşfet</div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Arka Plan Görseli" },
    { "type": "text",         "id": "eyebrow",          "label": "Üst Etiket",     "default": "Premium Çift Butiği" },
    { "type": "text",         "id": "title",             "label": "Başlık" },
    { "type": "textarea",     "id": "subtitle",          "label": "Alt Başlık",     "default": "Her ürün, özel anlarınızı unutulmaz kılmak için özenle seçildi. Premium materyal, tam gizlilik." },
    { "type": "text",         "id": "cta1_text",         "label": "Buton 1 Metni", "default": "Koleksiyonu Keşfet" },
    { "type": "url",          "id": "cta1_url",          "label": "Buton 1 Linki" },
    { "type": "text",         "id": "cta2_text",         "label": "Buton 2 Metni", "default": "Hakkımızda" },
    { "type": "url",          "id": "cta2_url",          "label": "Buton 2 Linki" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
